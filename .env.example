NODE_ENV=development
PORT=8787
DATABASE_URL=postgresql://sprout:sprout@localhost:5432/sprout
DATABASE_SSL=false
JWT_SECRET=replace-with-at-least-32-random-characters
CRON_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGINS=http://127.0.0.1:8080
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Production-safe defaults: manual-first V1 only.
ENABLE_REAL_VALUATIONS=false
ENABLE_EXTERNAL_CONNECTORS=false
ENABLE_STRUCTURED_IMPORTS=false
NAV_SOURCE=unavailable
FX_SOURCE=unavailable

# Set only after the 14-day report passes and human review is complete.
VALUATION_BURN_IN_APPROVED_AT=

# Optional paid source credentials. Never commit real values.
XE_ACCOUNT_ID=
XE_API_KEY=
