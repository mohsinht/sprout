{
  "name": "sprout-financial",
  "version": "0.1.0",
  "private": true,
  "description": "Sprout monorepo for a playful financial health companion for Pakistan.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r build && pnpm -r typecheck",
    "dev:api": "pnpm --filter @sprout/api dev",
    "dev:web": "cd apps/mobile && flutter run -d chrome --web-port=8080",
    "dev:web:hot": "cd apps/mobile && flutter run -d web-server --web-port=8080 --web-hostname=0.0.0.0",
    "test:e2e:local": "node scripts/e2e-local.mjs",
    "test:personas": "SPROUT_ENV=prod node scripts/persona-local.mjs",
    "traceability:build": "node scripts/build-traceability.mjs",
    "test:no-mocks": "bash scripts/check-no-mocks-in-release.sh",
    "test:golden": "pnpm --filter @sprout/shared build && pnpm --filter @sprout/api exec tsx --test src/harness/golden.test.ts",
    "test:money-invariants": "pnpm --filter @sprout/api exec tsx --test src/harness/money-invariants.integration.test.ts",
    "test:insights": "pnpm --filter @sprout/api exec tsx --test src/harness/insights.integration.test.ts",
    "test:ai-budget": "AI_DAILY_COST_CAP_CENTS=10 pnpm --filter @sprout/api exec tsx --test src/harness/ai-budget.integration.test.ts",
    "test:adversarial": "pnpm --filter @sprout/api exec tsx --test src/harness/adversarial.integration.test.ts && cd apps/mobile && flutter test test/transaction_row_test.dart --plain-name audit_d4_injection_description_renders_as_inert_text --dart-define=SPROUT_ENV=production",
    "test:ops": "pnpm --filter @sprout/api seed:valuation-mechanics && pnpm --filter @sprout/api exec tsx --test src/harness/ops.integration.test.ts",
    "test:score": "pnpm --filter @sprout/api test",
    "ops:valuation-gate": "node scripts/valuation-burn-in.mjs",
    "test:valuation-mechanics": "pnpm check && pnpm --filter @sprout/api seed:valuation-mechanics",
    "seed:ux-states": "DATABASE_URL=postgresql://sprout:sprout@localhost:5432/sprout pnpm --filter @sprout/api seed:ux-states",
    "ops:backup": "bash scripts/backup-postgres.sh",
    "ops:restore-smoke": "bash scripts/restore-smoke.sh",
    "format": "prettier --write .",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0"
    }
  }
}
