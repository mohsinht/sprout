# Sprout API environment variables

# Database (PostgreSQL)
DATABASE_URL=postgresql://sprout:sprout@localhost:5432/sprout

# Auth
JWT_SECRET=change-this-to-a-long-random-secret

# AI (optional — if not set, uses deterministic mock AI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OPENAI_REASONING_EFFORT=low

# Optional Xe Currency Data API credentials. If absent, non-PKR valuations
# remain explicitly unavailable; the backend never fabricates FX.
XE_ACCOUNT_ID=
XE_API_KEY=

# External sources (optional — if not set, uses mock sources)
FX_SOURCE=xe          # "xe", "exchange_rate_host", "mock", or "unavailable"
NAV_SOURCE=mock       # "mock" or "mufap"

# Cron (shared secret for the /v1/cron/daily endpoint)
CRON_SECRET=change-this-to-a-different-secret

# On-demand briefing rate limit (per user per hour)
ON_DEMAND_RATE_LIMIT=3

# Server
PORT=8787
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Stale thresholds
STALE_NAV_DAYS=2
STALE_FX_DAYS=1
