{
  "name": "@sprout/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm typecheck",
    "test": "tsx --test src/lib/*.test.ts src/audit.integration.test.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed:holdings": "tsx src/scripts/seed-holdings.ts",
    "seed:valuation-mechanics": "tsx src/scripts/seed-valuation-mechanics.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@sprout/domain": "workspace:*",
    "@sprout/shared": "workspace:*",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.16",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
